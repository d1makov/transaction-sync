# PPChange API Configuration
PPCHANGE_API_URL=https://ppchange.com.ua/parterapi/log/?partner_key=YOUR_API_KEY_HERE

# Google Sheets Configuration
GOOGLE_SHEET_NAME=admin
WORKSHEET_NAME=ppchange_transactions
CREDENTIALS_PATH=/opt/ppchange_api/credentials.json

# Email list (comma-separated)
